#!/usr/bin/env python3
"""
Brightness control — GNOME panel indicator (gamma-corrected).
Uses same curve as the hotkey popup. Works after GNOME Shell restart.
"""

import signal
import sys
import gi

gi.require_version("Gtk", "3.0")
gi.require_version("AyatanaAppIndicator3", "0.1")
from gi.repository import Gtk, AyatanaAppIndicator3 as AppIndicator, GLib

BRIGHTNESS_FILE = "/sys/class/backlight/intel_backlight/brightness"
MAX_HARDWARE = 19200
GAMMA = 0.55  # perception curve — matches the hotkey popup


def hardware_from_pct(pct: float) -> int:
    return int(MAX_HARDWARE * ((pct / 100.0) ** GAMMA))


def pct_from_hardware(val: int) -> float:
    ratio = val / MAX_HARDWARE
    if ratio <= 0:
        return 0.0
    return (ratio ** (1.0 / GAMMA)) * 100.0


def read_hardware() -> int:
    try:
        with open(BRIGHTNESS_FILE) as f:
            return int(f.read().strip())
    except (FileNotFoundError, ValueError, OSError):
        return 0


def write_hardware(val: int) -> None:
    val = max(0, min(MAX_HARDWARE, val))
    try:
        with open(BRIGHTNESS_FILE, "w") as f:
            f.write(str(val))
    except OSError as e:
        print(f"brightness-indicator: write failed — {e}", file=sys.stderr)


class BrightnessIndicator:
    def __init__(self):
        self.indicator = AppIndicator.Indicator.new(
            "brightness-indicator",
            "display-brightness-symbolic",
            AppIndicator.IndicatorCategory.HARDWARE,
        )
        self.indicator.set_status(AppIndicator.IndicatorStatus.ACTIVE)

        menu = Gtk.Menu()

        # ── slider row (0–100%) ──────────────────────────────────────
        slider_item = Gtk.MenuItem()
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        box.set_margin_start(12)
        box.set_margin_end(12)
        box.set_margin_top(6)
        box.set_margin_bottom(6)

        icon = Gtk.Image.new_from_icon_name(
            "display-brightness-symbolic", Gtk.IconSize.MENU
        )
        box.pack_start(icon, False, False, 0)

        self.slider = Gtk.Scale.new_with_range(
            Gtk.Orientation.HORIZONTAL, 0, 100, 1
        )
        self.slider.set_size_request(220, -1)
        self.slider.set_draw_value(True)
        self.slider.set_value_pos(Gtk.PositionType.RIGHT)
        self.slider.connect("value-changed", self._on_slider)
        box.pack_start(self.slider, True, True, 0)

        slider_item.add(box)
        slider_item.show_all()
        menu.append(slider_item)

        menu.append(Gtk.SeparatorMenuItem())

        # ── presets (percentage values) ──────────────────────────────
        for pct_label, pct_val in [
            ("Minimal  10%", 10),
            ("Low      25%", 25),
            ("Medium   50%", 50),
            ("High     75%", 75),
            ("Full    100%", 100),
        ]:
            item = Gtk.MenuItem(label=pct_label)
            item.connect("activate", lambda _, v=pct_val: self._set_pct(v))
            menu.append(item)

        menu.append(Gtk.SeparatorMenuItem())

        quit_item = Gtk.MenuItem(label="Quit")
        quit_item.connect("activate", lambda _: Gtk.main_quit())
        menu.append(quit_item)

        self.indicator.set_menu(menu)

        # initial value
        self._load()

        # poll for external changes
        GLib.timeout_add(2000, self._poll)

    def _pct_from_slider(self) -> float:
        return self.slider.get_value() if self.slider else 0

    def _set_pct(self, pct: int) -> None:
        hw = hardware_from_pct(pct)
        write_hardware(hw)
        if self.slider:
            self.slider.set_value(pct)

    def _on_slider(self, slider: Gtk.Scale) -> None:
        pct = slider.get_value()
        hw = hardware_from_pct(pct)
        write_hardware(hw)

    def _load(self) -> None:
        cur_hw = read_hardware()
        cur_pct = pct_from_hardware(cur_hw)
        if self.slider:
            self.slider.set_value(cur_pct)

    def _poll(self) -> bool:
        if not self.slider:
            return True
        actual_hw = read_hardware()
        current_pct = self.slider.get_value()
        expected_pct = pct_from_hardware(actual_hw)
        if abs(expected_pct - current_pct) > 2:
            self.slider.set_value(expected_pct)
        return True


if __name__ == "__main__":
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    BrightnessIndicator()
    Gtk.main()
