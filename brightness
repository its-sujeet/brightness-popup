#!/usr/bin/env python3
"""
Brightness control — popup slider with gamma curve.
Toggle: if already shown, bring to front or close+reopen.
Super+B → slider → presets → Escape to close.
"""

import os
import signal
import sys
import struct
import fcntl
import gi

gi.require_version("Gtk", "3.0")
from gi.repository import Gtk, GLib, Gdk

LOCK_FILE = "/tmp/brightness-popup.lock"
BRIGHTNESS_FILE = "/sys/class/backlight/intel_backlight/brightness"
MAX_HARDWARE = 19200
GAMMA = 0.55


def hardware_from_pct(pct: float) -> int:
    return int(MAX_HARDWARE * ((pct / 100.0) ** GAMMA))


def pct_from_hardware(val: int) -> float:
    ratio = val / MAX_HARDWARE
    if ratio <= 0:
        return 0.0
    return (ratio ** (1.0 / GAMMA)) * 100.0


def read_hardware() -> int:
    try:
        with open(BRIGHTNESS_FILE) as f:
            return int(f.read().strip())
    except (FileNotFoundError, ValueError, OSError):
        return 0


def write_hardware(val: int) -> None:
    val = max(0, min(MAX_HARDWARE, val))
    try:
        with open(BRIGHTNESS_FILE, "w") as f:
            f.write(str(val))
    except OSError as e:
        print(f"brightness: write failed — {e}", file=sys.stderr)


def acquire_lock() -> bool:
    """Try to acquire lock file. Returns True if we got it (first instance)."""
    try:
        fd = os.open(LOCK_FILE, os.O_CREAT | os.O_RDWR, 0o644)
        fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
        # Store our PID in the lock file
        os.write(fd, f"{os.getpid()}\n".encode())
        return True
    except (IOError, OSError):
        # Couldn't lock — another instance is running
        return False


def signal_existing() -> None:
    """Signal the running instance to toggle visibility."""
    try:
        with open(LOCK_FILE) as f:
            pid = int(f.read().strip().split("\n")[0])
        os.kill(pid, signal.SIGUSR1)
    except (FileNotFoundError, ValueError, ProcessLookupError, OSError):
        pass


class BrightnessPopup:
    def __init__(self):
        self.window = Gtk.Window(title="Brightness")
        self.window.set_type_hint(Gdk.WindowTypeHint.UTILITY)
        self.window.set_position(Gtk.WindowPosition.MOUSE)
        self.window.set_default_size(300, 90)
        self.window.set_resizable(False)
        self.window.set_keep_above(True)
        self.window.set_skip_taskbar_hint(True)
        self.window.set_skip_pager_hint(True)
        self.window.set_decorated(False)

        self.window.connect("key-press-event", self._on_key)
        self.window.connect("delete-event", self._on_close)

        # dark theme
        css = Gtk.CssProvider()
        css.load_from_data(b"""
            window { background: #1a1a1a; }
            label { color: #ddd; font-size: 11pt; }
            scale slider {
                background: #ddd;
                border-radius: 10px;
                min-width: 18px;
                min-height: 18px;
            }
            scale trough { min-height: 6px; background: #333; border-radius: 3px; }
            scale fill  { background: #666; border-radius: 3px; }
            button {
                background: #2a2a2a;
                color: #ccc;
                border: 1px solid #444;
                border-radius: 4px;
                font-size: 10pt;
            }
            button:hover { background: #3a3a3a; }
        """)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), css, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        vbox.set_margin_start(12)
        vbox.set_margin_end(12)
        vbox.set_margin_top(10)
        vbox.set_margin_bottom(10)

        top = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        icon = Gtk.Image.new_from_icon_name(
            "display-brightness-symbolic", Gtk.IconSize.BUTTON
        )
        top.pack_start(icon, False, False, 0)

        cur_hw = read_hardware()
        cur_pct = pct_from_hardware(cur_hw)
        self.label = Gtk.Label(label=f"Brightness  {round(cur_pct)}%")
        top.pack_start(self.label, True, True, 0)
        vbox.pack_start(top, False, False, 0)

        self.slider = Gtk.Scale.new_with_range(
            Gtk.Orientation.HORIZONTAL, 0, 100, 1
        )
        self.slider.set_size_request(260, -1)
        self.slider.set_value(cur_pct)
        self.slider.connect("value-changed", self._on_slider)
        vbox.pack_start(self.slider, True, True, 0)

        preset_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
        preset_box.set_halign(Gtk.Align.CENTER)
        preset_box.set_margin_top(4)
        for pct_label, pct_val in [
            ("10%", 10), ("25%", 25), ("50%", 50),
            ("75%", 75), ("100%", 100),
        ]:
            btn = Gtk.Button(label=pct_label)
            btn.set_size_request(48, 24)
            btn.connect("clicked", lambda _, v=pct_val: self._set_pct(v))
            preset_box.pack_start(btn, False, False, 0)
        vbox.pack_start(preset_box, False, False, 0)

        hint = Gtk.Label(label="Esc to close")
        hint.set_opacity(0.4)
        hint.set_margin_top(4)
        vbox.pack_start(hint, False, False, 0)

        self.window.add(vbox)
        self.window.show_all()
        self.window.present_with_time(Gdk.CURRENT_TIME)

        # auto-close timer
        self._timer_id = GLib.timeout_add_seconds(15, self._hide_on_timeout)

        # listen for SIGUSR1 → toggle close
        GLib.unix_signal_add(GLib.PRIORITY_HIGH, signal.SIGUSR1, self._on_toggle, None)

    def _on_slider(self, slider):
        pct = slider.get_value()
        hw = hardware_from_pct(pct)
        write_hardware(hw)
        self.label.set_text(f"Brightness  {round(pct)}%")

    def _set_pct(self, pct):
        hw = hardware_from_pct(pct)
        write_hardware(hw)
        self.slider.set_value(pct)

    def _on_key(self, win, event):
        if event.keyval == Gdk.KEY_Escape:
            Gtk.main_quit()
        return False

    def _on_close(self, *args):
        Gtk.main_quit()
        return True

    def _hide_on_timeout(self) -> bool:
        Gtk.main_quit()
        return False

    def _on_toggle(self, *args) -> bool:
        """SIGUSR1 received — another Super+B press, toggle close."""
        Gtk.main_quit()
        return True


if __name__ == "__main__":
    signal.signal(signal.SIGUSR1, signal.SIG_IGN)  # default handler

    if not acquire_lock():
        # Already running — signal it to close (toggle off)
        signal_existing()
        sys.exit(0)

    # First instance — show the popup
    BrightnessPopup()
    Gtk.main()

    # Clean up lock on exit
    try:
        os.unlink(LOCK_FILE)
    except OSError:
        pass
