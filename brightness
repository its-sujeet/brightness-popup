#!/usr/bin/env python3
"""
Brightness control — gamma-corrected popup with extended dark range.
Slider goes -40 (barely glowing) to 100 (full). Negative values = slow 
gradual descent into dark, step by step.
Toggle on/off with Super+B.
"""

import os
import signal
import sys
import fcntl
import gi

gi.require_version("Gtk", "3.0")
from gi.repository import Gtk, GLib, Gdk

LOCK_FILE = "/tmp/brightness-popup.lock"
BRIGHTNESS_FILE = "/sys/class/backlight/intel_backlight/brightness"
MAX_HARDWARE = 19200
SLIDER_MIN = -40
SLIDER_MAX = 100
GAMMA = 2.2  # steeper curve spreads the low end wider


def hardware_from_slider(s: float) -> int:
    """Map slider value (-40..100) → hardware (0..MAX)."""
    t = (s - SLIDER_MIN) / (SLIDER_MAX - SLIDER_MIN)  # 0..1
    t = max(0.0, min(1.0, t))
    return int(MAX_HARDWARE * (t ** GAMMA))


def slider_from_hardware(hw: int) -> float:
    """Inverse: hardware → slider value."""
    ratio = max(0.0, min(1.0, hw / MAX_HARDWARE))
    if ratio <= 0:
        return float(SLIDER_MIN)
    t = ratio ** (1.0 / GAMMA)
    return SLIDER_MIN + t * (SLIDER_MAX - SLIDER_MIN)


def read_hardware() -> int:
    try:
        with open(BRIGHTNESS_FILE) as f:
            return int(f.read().strip())
    except (FileNotFoundError, ValueError, OSError):
        return 0


def write_hardware(val: int) -> None:
    val = max(0, min(MAX_HARDWARE, val))
    try:
        with open(BRIGHTNESS_FILE, "w") as f:
            f.write(str(val))
    except OSError as e:
        print(f"brightness: write failed — {e}", file=sys.stderr)


def display_value(s: float) -> str:
    """Format slider value for the label: -40 → '-40' etc."""
    n = round(s)
    if n >= 0:
        return str(n)
    return str(n)  # Gtk scale already shows negative


def acquire_lock() -> int | None:
    try:
        fd = os.open(LOCK_FILE, os.O_CREAT | os.O_RDWR, 0o644)
        fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
        os.lseek(fd, 0, os.SEEK_SET)
        os.ftruncate(fd, 0)
        os.write(fd, f"{os.getpid()}\n".encode())
        os.fsync(fd)
        return None
    except (IOError, OSError):
        try:
            with open(LOCK_FILE) as f:
                return int(f.read().strip().split("\n")[0])
        except (FileNotFoundError, ValueError, OSError):
            return None


class BrightnessPopup:
    def __init__(self):
        self.window = Gtk.Window(title="Brightness")
        self.window.set_type_hint(Gdk.WindowTypeHint.UTILITY)
        self.window.set_position(Gtk.WindowPosition.MOUSE)
        self.window.set_default_size(320, 110)
        self.window.set_resizable(False)
        self.window.set_keep_above(True)
        self.window.set_skip_taskbar_hint(True)
        self.window.set_skip_pager_hint(True)
        self.window.set_decorated(False)

        self.window.connect("key-press-event", self._on_key)
        self.window.connect("delete-event", lambda *a: Gtk.main_quit())

        # dark theme
        css = Gtk.CssProvider()
        css.load_from_data(b"""
            window { background: #111; }
            label { color: #ccc; font-size: 11pt; }
            scale slider {
                background: #ccc;
                border-radius: 10px;
                min-width: 18px;
                min-height: 18px;
            }
            scale trough { min-height: 6px; background: #222; border-radius: 3px; }
            scale fill  { background: #555; border-radius: 3px; }
            button {
                background: #222;
                color: #bbb;
                border: 1px solid #333;
                border-radius: 4px;
                font-size: 10pt;
            }
            button:hover { background: #333; }
        """)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), css, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        vbox.set_margin_start(14)
        vbox.set_margin_end(14)
        vbox.set_margin_top(12)
        vbox.set_margin_bottom(12)

        # ── top row: icon + value ──────────────────────────────────
        top = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        icon = Gtk.Image.new_from_icon_name(
            "display-brightness-symbolic", Gtk.IconSize.BUTTON
        )
        top.pack_start(icon, False, False, 0)

        cur_hw = read_hardware()
        cur_s = slider_from_hardware(cur_hw)
        self.label = Gtk.Label(label=f"Brightness  {round(cur_s)}")
        top.pack_start(self.label, True, True, 0)
        vbox.pack_start(top, False, False, 0)

        # ── slider ─────────────────────────────────────────────────
        self.slider = Gtk.Scale.new_with_range(
            Gtk.Orientation.HORIZONTAL, SLIDER_MIN, SLIDER_MAX, 1
        )
        self.slider.set_size_request(280, -1)
        self.slider.set_value(cur_s)
        self.slider.connect("value-changed", self._on_slider)
        vbox.pack_start(self.slider, True, True, 0)

        # ── presets ─────────────────────────────────────────────────
        preset_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=3)
        preset_box.set_halign(Gtk.Align.CENTER)
        preset_box.set_margin_top(4)
        for label, val in [
            ("-30", -30), ("-20", -20), ("-10", -10),
            ("0", 0), ("25", 25), ("50", 50), ("75", 75), ("100", 100),
        ]:
            btn = Gtk.Button(label=label)
            btn.set_size_request(32, 22)
            btn.connect("clicked", lambda _, v=val: self._set(v))
            preset_box.pack_start(btn, False, False, 0)
        vbox.pack_start(preset_box, False, False, 0)

        # ── hint ────────────────────────────────────────────────────
        hint = Gtk.Label(label="Esc to close  ·  Super+B toggles")
        hint.set_opacity(0.35)
        hint.set_margin_top(2)
        vbox.pack_start(hint, False, False, 0)

        self.window.add(vbox)
        self.window.show_all()
        self.window.present_with_time(Gdk.CURRENT_TIME)

        # auto-close
        GLib.timeout_add_seconds(20, Gtk.main_quit)

    def _on_slider(self, slider):
        s = slider.get_value()
        hw = hardware_from_slider(s)
        write_hardware(hw)
        self.label.set_text(f"Brightness  {round(s)}")

    def _set(self, val):
        hw = hardware_from_slider(val)
        write_hardware(hw)
        self.slider.set_value(val)

    def _on_key(self, win, event):
        if event.keyval == Gdk.KEY_Escape:
            Gtk.main_quit()
        return False


if __name__ == "__main__":
    existing_pid = acquire_lock()

    if existing_pid is not None:
        try:
            os.kill(existing_pid, signal.SIGTERM)
        except (ProcessLookupError, PermissionError, OSError):
            pass
        try:
            os.unlink(LOCK_FILE)
        except OSError:
            pass
        sys.exit(0)

    BrightnessPopup()
    Gtk.main()

    try:
        os.unlink(LOCK_FILE)
    except OSError:
        pass
